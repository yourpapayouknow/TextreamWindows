{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Textream",
  "version": "0.1.0",
  "identifier": "dev.fka.textream.windows",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Textream",
        "width": 1080,
        "height": 760,
        "minWidth": 880,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "A Windows teleprompter with word tracking and remote control.",
    "longDescription": "Textream for Windows is a Tauri port of the macOS teleprompter with script editing, overlay windows, remote viewing, director mode, and local speech backend boundaries.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
